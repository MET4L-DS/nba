#!/bin/bash

# AWS Deployment Setup Script for PHP/MySQL (LEMP Stack) on Ubuntu
# Usage: sudo ./setup_aws.sh

echo "Starting NBA Deployment Setup (LEMP Stack)..."

# 1. Update System
echo "Updating system packages..."
apt update && apt upgrade -y

# 2. Install Nginx
echo "Installing Nginx Web Server..."
apt install -y nginx
systemctl start nginx
systemctl enable nginx

# 3. Install MySQL Server
echo "Installing MySQL Server..."
apt install -y mysql-server
systemctl start mysql
systemctl enable mysql

# 4. Install PHP (FPM) and extensions
echo "Installing PHP-FPM and dependencies..."
# Determine PHP version usually available (e.g., 8.1 on Ubuntu 22.04)
apt install -y php-fpm php-mysql php-curl php-json php-mbstring php-xml php-zip

# 5. Set up directory permissions
echo "Setting up directory permissions..."
# Create html dir if not exists (Nginx sometimes uses /var/www/html)
mkdir -p /var/www/html
chown -R ubuntu:www-data /var/www/html
chmod -R 775 /var/www/html

echo "=========================================================="
echo "Installation complete!"
echo "Next steps:"
echo "1. Secure MySQL installation: 'sudo mysql_secure_installation'"
echo "2. Create Database & User:"
echo "   sudo mysql -u root"
echo "   > CREATE DATABASE nba_db;"
echo "   > CREATE USER 'nba_user'@'localhost' IDENTIFIED BY 'nba@420';"
echo "   > GRANT ALL PRIVILEGES ON nba_db.* TO 'nba_user'@'localhost';"
echo "   > FLUSH PRIVILEGES;"
echo "   > EXIT;"
echo "3. Copy your project files to /var/www/html/nba"
echo "4. Configure Nginx Server Block to point to /var/www/html/nba/api"
echo "5. Add environment variables to /etc/php/X.X/fpm/pool.d/www.conf"
echo "=========================================================="
